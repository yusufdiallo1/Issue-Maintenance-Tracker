# ============================================================
#  Issue & Maintenance Tracker — Env Template (Next.js)
#  Copy to .env and fill in real values. Never commit .env.
#
#  NEXT_PUBLIC_* vars are exposed to the BROWSER. Only safe,
#  public keys belong there. Unprefixed vars stay SERVER-ONLY.
# ============================================================

# ---- Supabase (public / browser-safe) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ---- Supabase (server-only — NEVER prefix with NEXT_PUBLIC_) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=sb_secret_xxx

# ---- Groq Cloud (server-only) ----
GROQ_API_KEY=gsk_xxx
